    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
